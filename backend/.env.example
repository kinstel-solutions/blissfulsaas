# Database Configuration (Supabase)
# DATABASE_URL is the connection pooling URL (transaction mode)
DATABASE_URL="postgresql://user:pass@host:6543/postgres?pgbouncer=true"
# DIRECT_URL is the direct connection URL (session mode) for migrations
DIRECT_URL="postgresql://user:pass@host:5432/postgres"

# Supabase Auth
# Find these in Supabase Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Server Configuration
PORT=5000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# External Services - Agora (Video)
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-app-certificate

# External Services - Razorpay (Payments)
# Set MOCK_PAYMENT=true for development/testing without real charges
MOCK_PAYMENT=true
RAZORPAY_KEY_ID=rzp_test_placeholder
RAZORPAY_KEY_SECRET=placeholder_secret
