generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PATIENT
  THERAPIST
  ADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
  EXPIRED
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  REFUNDED
}

enum ConsultationMode {
  ONLINE
  IN_CLINIC
}

model User {
  id        String   @id @db.Uuid // Must match Supabase auth.users.id exactly
  email     String   @unique
  role      Role     @default(PATIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patientProfile   Patient?
  therapistProfile Therapist?
  adminProfile     Admin?
  messages         Message[]
  notifications    Notification[]
}

model Patient {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @unique @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  firstName   String?
  lastName    String?
  phone       String?
  dateOfBirth DateTime?

  // Clinical Intake Form
  intakeCompleted      Boolean  @default(false)
  reasonForSeeking     String?
  mentalHealthHistory  String?
  currentMedications   String?
  previousTherapy      Boolean?
  therapyGoals         String?
  emergencyContactName  String?
  emergencyContactPhone String?
  primaryConcerns      String[]

  appointments Appointment[]
}

model Therapist {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @unique @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  firstName     String?
  lastName      String?
  gender        String?
  phone         String?
  bio           String?
  qualifications String?  // e.g. "M.Phil Clinical Psychology"
  specialities  String[]
  languages     String[]  // e.g. ["English", "Hindi"]
  yearsOfExperience Int?
  videoUrl      String?
  hourlyRate    Float?
  clinicAddress String?  // Physical address for in-clinic appointments
  mapLink       String?  // Google Maps link for the clinic location
  profileImageUrl String? // URL for therapist profile image
  rciNumber       String?  // RCI or MCI Registration Number
  licenceCertificateUrl String? // Uploaded licence/certificate image URL
  bankName        String?
  bankAccountNumber String?
  bankIfscCode    String?
  bankAccountHolderName String?
  panNumber       String?
  aadhaarNumber   String?
  isVerified    Boolean  @default(false)
  rejectionReason String?
  pendingFields Json?    // To store updates awaiting admin approval

  weeklySchedule    WeeklyAvailability[]
  scheduleOverrides ScheduleOverride[]
  appointments      Appointment[]
  feedbacks         SessionFeedback[]
}

model Admin {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @unique @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// AVAILABILITY RULE MODELS — store the RULES, generate slots dynamically
// ---------------------------------------------------------------------------

model WeeklyAvailability {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  therapistId String   @db.Uuid
  therapist   Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  dayOfWeek   Int              // 0 = Sunday … 6 = Saturday
  startTime   String           // "09:00" HH:mm UTC
  endTime     String           // "17:00" HH:mm UTC
  mode        ConsultationMode // ONLINE | IN_CLINIC
  isActive    Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([therapistId, dayOfWeek, mode])
  @@index([therapistId])
}

model ScheduleOverride {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  therapistId String   @db.Uuid
  therapist   Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  date        DateTime         // The specific calendar date (midnight UTC)
  isAvailable Boolean          // false = full day off
  startTime   String?          // "10:00" HH:mm UTC — only when isAvailable = true
  endTime     String?          // "14:00" HH:mm UTC — only when isAvailable = true
  mode        ConsultationMode? // null = applies to all modes
  reason      String?          // Optional label e.g. "Holiday", "Conference"

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([therapistId, date, mode])
  @@index([therapistId, date])
}

model Appointment {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId     String            @db.Uuid
  patient       Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  therapistId   String            @db.Uuid
  therapist     Therapist         @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  scheduledAt   DateTime          // Exact date+time of this session (UTC)
  duration      Int               @default(50) // Duration in minutes (50 min session + 10 min buffer = 1 hour block)

  status        AppointmentStatus @default(PENDING)
  mode          ConsultationMode  @default(ONLINE)
  videoRoomId   String            @unique @default(dbgenerated("gen_random_uuid()"))
  patientNotes  String?
  therapistNotes String?

  // Payment fields
  paymentStatus  PaymentStatus @default(UNPAID)
  paymentId      String?       // Razorpay payment ID (or MOCK-xxx in mock mode)
  amountPaid     Float?        // Amount in INR
  paidAt         DateTime?

  messages      Message[]
  feedback      SessionFeedback?

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  reminderSent  Boolean           @default(false)

  @@index([patientId, scheduledAt])
  @@index([therapistId, scheduledAt])
}

model SessionFeedback {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  appointmentId String      @unique @db.Uuid
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  therapistId   String      @db.Uuid   // denormalised for fast aggregate queries
  therapist     Therapist   @relation(fields: [therapistId], references: [id])
  rating        Int                    // 1–5 star rating
  comment       String?               // optional written review
  isPublic      Boolean     @default(true)  // admin can hide
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([therapistId])
}

model Message {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  appointmentId String      @db.Uuid
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  senderId      String      @db.Uuid
  sender        User        @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content       String
  isRead        Boolean     @default(false)
  createdAt     DateTime    @default(now())

  @@index([appointmentId, createdAt])
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  SESSION_COMPLETED
  PAYMENT_SUCCESS
  THERAPIST_APPROVED
  NEW_MESSAGE
  FEEDBACK_REQUEST
  GENERAL
}

model Notification {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String           @db.Uuid
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType @default(GENERAL)
  title     String
  body      String
  isRead    Boolean          @default(false)
  metadata  Json?            // e.g. { appointmentId, therapistName, amount }
  createdAt DateTime         @default(now())

  @@index([userId, createdAt])
  @@index([userId, isRead])
}
