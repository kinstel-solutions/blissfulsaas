generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PATIENT
  THERAPIST
  ADMIN
}

model User {
  id        String   @id @db.Uuid // Must match Supabase auth.users.id exactly
  email     String   @unique
  role      Role     @default(PATIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patientProfile   Patient?
  therapistProfile Therapist?
  adminProfile     Admin?
}

model Patient {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @unique @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  firstName   String?
  lastName    String?
  phone       String?
  dateOfBirth DateTime?
}

model Therapist {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @unique @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  firstName     String?
  lastName      String?
  bio           String?
  specialities  String[]
  videoUrl      String?
  hourlyRate    Float?
  isVerified    Boolean  @default(false)
}

model Admin {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @unique @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
